# Draculative Alpha Engine — Environment Variables
# Copy this file to .env and fill in your Alpaca keys.
# NEVER commit the real .env to git.

ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Optional — override the base URL for live trading (default is paper)
# ALPACA_BASE_URL=https://api.alpaca.markets
